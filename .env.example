# Copy this file to ".env" and fill in the values from your Salesforce Connected App.

# From Setup > App Manager > New Connected App
SF_CLIENT_ID=your_connected_app_consumer_key
SF_CLIENT_SECRET=your_connected_app_consumer_secret

# Must EXACTLY match the "Callback URL" you set on the Connected App
SF_CALLBACK_URL=http://localhost:3000/auth/callback

# Use https://login.salesforce.com for normal Dev Edition / Production orgs
# Use https://test.salesforce.com for Sandboxes
SF_LOGIN_URL=https://login.salesforce.com

# Any random long string, used to sign the session cookie
SESSION_SECRET=change_this_to_a_long_random_string

PORT=3000
